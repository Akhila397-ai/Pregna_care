{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
     "typeRoots": ["./node_modules/@types", "./src/types"],
      "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2020",

    "types": ["node"],

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "strict": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  }
}